# Normalize line endings: let Git handle text automatically,
# but force LF for files that must use LF in a Linux container.
* text=auto eol=lf

*.sh text eol=lf
docker-entrypoint.sh text eol=lf
Dockerfile text eol=lf

# Binary files Git should never touch
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.pdf binary
